# ========================================
# |  Notification Configuration
# ========================================
# 1. PushPlus (http://www.pushplus.plus/)
PUSHPLUS_TOKEN=
# 2. WXPusher (http://wxpusher.zjiecode.com/admin/)
WXPUSHER_APP_TOKEN=
# UID 是个人订阅者标识，每个关注应用的用户都有唯一 UID，多个用 , 分隔
WXPUSHER_UIDS=
# Topic ID 是 WXPusher 后台创建的主题 ID（用于广播/群发），多个用 , 分隔
WXPUSHER_TOPIC_IDS=
# 3. DingTalk Robot (https://open.dingtalk.com/document/robots/custom-robot-access)
DINGTALK_ACCESS_TOKEN=
DINGTALK_SECRET=
# 4. Email (SMTP)
# SMTP 配置
SMTP_HOST=smtp.qq.com
# SMTP 端口
SMTP_PORT=465
# SMTP 用户名
SMTP_USER=
# SMTP 授权码
SMTP_PASS=
# 收件人邮箱
SMTP_TO=

# ========================================
# |  雨云登录凭据
# ========================================
# 支持多账号，多个账号/密码之间请使用竖线 | 分隔
# 例如: 
# RAINYUN_USERNAME=user1@example.com|user2@example.com
# RAINYUN_PASSWORD=password1|password2
RAINYUN_USERNAME=your_email@example.com
RAINYUN_PASSWORD=your_password

# 运行模式配置
# 定时任务执行时间 (仅 schedule 模式有效)，格式 HH:MM
SCHEDULE_TIME=08:00
# 应用时区（默认上海时间）
TZ=Asia/Shanghai

# 可选配置
# 是否开启调试日志 (true/false)
DEBUG=false
# 多账号并行执行的错峰启动最大随机延时（秒）
MAX_DELAY=15
# 最大并发线程数（默认为3），如果要开5并发请修改此处
MAX_WORKERS=3
# 请求超时时间(毫秒)
TIMEOUT=30000
# 签到失败最大重试次数（默认为2次）
CHECKIN_MAX_RETRIES=2

# ========================================
# |  代理IP配置（可选）
# ========================================
# 代理IP接口地址，每个账号签到前会单独请求一次获取新代理
# 支持返回格式：
#   - 纯文本: 192.168.1.1:8080
#   - JSON: {"ip": "192.168.1.1", "port": 8080}
#   - JSON: {"proxy": "192.168.1.1:8080"}
#   - JSON: {"code": 0, "data": {"ip": "x.x.x.x", "port": 8080}}
# 不填则不使用代理
PROXY_API_URL=

# ========================================
# |  截图压缩配置（可选）
# ========================================
# TinyPNG API Key (https://tinypng.com/developers)
# - 每月免费额度 500 次
# - 单张图片最大 5MB
# - 不填则使用本地 Pillow 压缩
TINYPNG_API_KEY=

# ========================================
# |  推送截图配置（可选）
# ========================================
# 截图嵌入策略：
#   all          - 所有账号（成功+失败）都带截图
#   failed_only  - 仅失败账号带截图（默认，推荐）
#   none         - 不嵌入任何截图
# 提示：截图会以 Base64 编码嵌入推送内容，
# 多个账号可能导致内容超过渠道限制（如 PushPlus 2万字），
# 超限时会自动降级到不带截图的精简版本。
SCREENSHOT_MODE=failed_only
