# ========================================
# |  ChmlFrp 登录凭据（必填）
# ========================================
# 支持多账号，多个账号/密码之间请使用竖线 | 分隔
# 例如:
# CHMLFRP_USERNAME=user1@example.com|user2@163.com
# CHMLFRP_PASSWORD=password1|password2
CHMLFRP_USERNAME=yydswudiyishi@163.com
CHMLFRP_PASSWORD=zhanxiong123456

# ========================================
# |  IMAP 邮箱验证码配置（必填，用于 MFA 验证）
# ========================================
# 用于自动读取登录时的邮箱验证码
# 163邮箱: imap.163.com / 993
# QQ邮箱: imap.qq.com / 993
IMAP_HOST=imap.163.com
IMAP_PORT=993
IMAP_USER=yydswudiyishi@163.com
IMAP_PASSWORD=UHP8CUrwzNtkvUhW

# ========================================
# |  Notification Configuration（可选）
# ========================================
# 1. PushPlus (http://www.pushplus.plus/)
PUSHPLUS_TOKEN=
# 2. WXPusher (http://wxpusher.zjiecode.com/admin/)
WXPUSHER_APP_TOKEN=
WXPUSHER_UIDS=
WXPUSHER_TOPIC_IDS=
# 3. DingTalk Robot
DINGTALK_ACCESS_TOKEN=
DINGTALK_SECRET=
# 4. Email (SMTP)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_TO=

# ========================================
# |  运行模式配置
# ========================================
# 运行模式: schedule（定时）/ once（单次）
RUN_MODE=once
# 定时任务执行时间 (仅 schedule 模式有效)，格式 HH:MM
SCHEDULE_TIME=08:00
# 应用时区（默认上海时间）
TZ=Asia/Shanghai

# ========================================
# |  可选配置
# ========================================
# 是否开启调试日志 (true/false)
DEBUG=false
# 多账号并行执行的错峰启动最大随机延时（秒）
MAX_DELAY=15
# 最大并发线程数
MAX_WORKERS=3
# 请求超时时间(毫秒)
TIMEOUT=30000
# 签到失败最大重试次数
CHECKIN_MAX_RETRIES=2

# ========================================
# |  代理IP配置（可选）
# ========================================
PROXY_API_URL=

# ========================================
# |  推送截图配置（可选）
# ========================================
# all / failed_only / none
SCREENSHOT_MODE=failed_only
